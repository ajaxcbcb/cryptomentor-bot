# ============================================
# WEBSITE BACKEND - ENVIRONMENT VARIABLES
# ============================================

# Domain website (isi setelah dapat domain)
WEBSITE_DOMAIN=https://yourdomain.com
FRONTEND_URL=https://yourdomain.com

# ============================================
# TELEGRAM BOT (WAJIB untuk Login)
# ============================================
# Harus sama dengan bot token di Bismillah/.env
TELEGRAM_BOT_TOKEN=replace_with_real_telegram_bot_token
TELEGRAM_BOT_USERNAME=CryptoMentorAI_bot
# Telegram login payload age limit (seconds). Default: 86400 (24h)
TELEGRAM_AUTH_MAX_AGE_SECONDS=86400

# ============================================
# JWT SECRET
# ============================================
JWT_SECRET=replace_with_random_64_plus_hex_chars
JWT_EXPIRE_HOURS=24
# Required for signed 1-click signal tokens (preview + execute)
ONE_CLICK_SIGNAL_SIGNING_KEY=replace_with_random_32_plus_chars

# ============================================
# SUPABASE (shared dengan bot)
# ============================================
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=replace_with_supabase_anon_key
SUPABASE_SERVICE_KEY=replace_with_supabase_service_role_key
TESTIMONIALS_AVATAR_BUCKET=testimonial-avatars
TESTIMONIALS_AVATAR_MAX_BYTES=5242880

# ============================================
# SERVER
# ============================================
PORT=8000
DEBUG=false

# Encryption key untuk decrypt API keys user (HARUS sama dengan Bismillah bot ENCRYPTION_KEY)
# Ambil dari Bismillah/.env -> ENCRYPTION_KEY
ENCRYPTION_KEY=replace_with_fernet_key_from_bismillah_env
